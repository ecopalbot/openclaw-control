# ═══════════════════════════════════════════════════════════════
# OpenClaw + BMAD — Environment Variables
# Lives at ~/.openclaw/.env on the VPS (OpenClaw reads this natively)
# NEVER commit with real values. Copy .env.example → .env
# ═══════════════════════════════════════════════════════════════

# ── LLM Providers (OpenClaw reads these directly) ─────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── OpenClaw Gateway ──────────────────────────────────────────
OPENCLAW_GATEWAY_TOKEN=

# ── Telegram (OpenClaw native channel) ────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=

# ── Supabase (BMAD extension layer) ──────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# ── Organization ──────────────────────────────────────────────
ORG_NAME=
ORG_OWNER_IDENTITY=
ORG_VALUES_MANIFEST=

# ── Hard Safety Limits (Tier 1 — cannot be exceeded) ─────────
MAX_DAILY_SPEND_HARD=25.00
MAX_PER_AGENT_TOKENS_HARD=500000
MAX_PER_TASK_TOKENS_HARD=200000

# ── Dashboard ─────────────────────────────────────────────────
DASHBOARD_PORT=3001

# ── Kimi AI (separate provider — NOT OpenAI key) ─────────────
KIMI_API_KEY=
KIMI_BASE_URL=

# ── Voice Integration (placeholder) ──────────────────────────
STT_PROVIDER=
TTS_PROVIDER=
STT_API_KEY=
TTS_API_KEY=
